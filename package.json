{
  "name": "ecommerce-miniapp",
  "version": "1.0.0",
  "private": true,
  "description": "E-commerce mini-app — Next.js + NestJS + PostgreSQL",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @app/api prisma:generate",
    "db:push": "pnpm --filter @app/api prisma:push",
    "db:seed": "pnpm --filter @app/api prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2",
      "sharp",
      "unrs-resolver"
    ]
  }
}
