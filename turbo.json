{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "DATABASE_URL",
    "JWT_ACCESS_SECRET",
    "ACCESS_TOKEN_TTL",
    "REFRESH_TOKEN_TTL_DAYS",
    "INACTIVITY_TIMEOUT_MINUTES",
    "CORS_ORIGIN",
    "COOKIE_DOMAIN",
    "NODE_ENV",
    "NEXT_PUBLIC_API_URL",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
