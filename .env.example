# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# The same DATABASE_URL is used whether you target Neon (dev)
# or the local Postgres from docker-compose (evaluator).
# ─────────────────────────────────────────────────────────────

# --- Database ---
# Local (docker-compose):
#   postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public
# Neon (dev): copy the pooled connection string from the Neon dashboard
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public"

# --- Auth / JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"
INACTIVITY_TIMEOUT_MINUTES="30"

# --- API server ---
PORT="3001"
NODE_ENV="development"
# Comma-separated list of allowed browser origins
CORS_ORIGIN="http://localhost:3000"
# Leave empty for localhost; set in production (e.g. ".example.com")
COOKIE_DOMAIN=""

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
